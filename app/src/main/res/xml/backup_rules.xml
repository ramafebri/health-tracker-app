<?xml version="1.0" encoding="utf-8"?>
<!--
   Excludes GPS workout routes and in-progress session state from Android Auto Backup.
   See https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <exclude domain="database" path="health_tracker.db" />
    <exclude domain="database" path="health_tracker.db-shm" />
    <exclude domain="database" path="health_tracker.db-wal" />
    <exclude domain="file" path="datastore/workout_prefs.preferences_pb" />
</full-backup-content>
