<?xml version="1.0" encoding="utf-8"?>
<!--
   Excludes GPS workout routes and in-progress session state from cloud backup
   and device-to-device transfer (API 31+).
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="health_tracker.db" />
        <exclude domain="database" path="health_tracker.db-shm" />
        <exclude domain="database" path="health_tracker.db-wal" />
        <exclude domain="file" path="datastore/workout_prefs.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="health_tracker.db" />
        <exclude domain="database" path="health_tracker.db-shm" />
        <exclude domain="database" path="health_tracker.db-wal" />
        <exclude domain="file" path="datastore/workout_prefs.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
